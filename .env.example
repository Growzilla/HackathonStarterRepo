# Your Shopify store credentials (from Discord)
# Token starts with shpua_ — do NOT use the shpss_ secret
SHOPIFY_ACCESS_TOKEN=shpua_your_token_here
SHOPIFY_STORE_URL=gzh-XX.myshopify.com

# Order simulator (creates fake orders every 60-180 seconds)
SIMULATOR_ENABLED=true
SIMULATOR_INTERVAL_MIN=60
SIMULATOR_INTERVAL_MAX=180
